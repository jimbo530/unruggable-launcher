# MfT-Launch — example environment file. Copy to .env and fill in real values.
# NEVER commit a real .env. No secrets belong in source.

# Base mainnet RPC (Alchemy or other provider). Used by hardhat.config.js for the
# `base` network and for the FORK_E2E=1 mainnet-fork tests.
ALCHEMY_RPC=https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Optional: overrides ALCHEMY_RPC for the fork-only e2e tests (e.g. a drpc endpoint).
FORK_RPC=

# Set FORK_E2E=1 to enable the Base mainnet fork in test/e2e-fork-v9.js (requires
# ALCHEMY_RPC or FORK_RPC). FORK_BLOCK pins the fork block for determinism.
FORK_E2E=
FORK_BLOCK=

# Deployer key for hardhat `base` network accounts. Keep this secret.
DEPLOY_PRIVATE_KEY=

# Basescan API key for contract verification.
BASESCAN_API_KEY=

# Claude API
ANTHROPIC_API_KEY=sk-ant-...

# X/Twitter API (same creds as x-poster)
API_KEY=
API_SECRET=
ACCESS_TOKEN=
ACCESS_TOKEN_SECRET=

# Farcaster (Neynar API — free tier: 300 req/day)
NEYNAR_API_KEY=

# Farcaster account FID (jamesmagee)
FARCASTER_FID=

# Farcaster signer UUID (from Neynar managed signer)
FARCASTER_SIGNER_UUID=

# Optional: dry run mode (no actual posts)
DRY_RUN=false

# Intervals (minutes)
CONTENT_INTERVAL=120
SCOUT_INTERVAL=60
OUTREACH_INTERVAL=180

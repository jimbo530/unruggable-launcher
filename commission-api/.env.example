# commission-api — example environment file. Copy to .env and fill in real values.
# NEVER commit a real .env. No secrets belong in source.

# REQUIRED. Secret key that guards the admin endpoints (/list, /status).
# There is NO default — if this is unset, the admin endpoints fail closed (always 403).
COMMISSION_ADMIN_KEY=

# Optional: port (default 3060).
COMMISSION_PORT=3060

# Wallet that must receive the USDC commission payment (has a baked-in default in
# server.js; set here to override).
COMMISSION_WALLET=

# Optional: minimum USDC (6 decimals) required to accept a commission (default 9500000 = $9.50).
COMMISSION_MIN_USDC=9500000

# RPC endpoints used to verify on-chain USDC payments. Falls back to public RPCs if unset.
ALCHEMY_RPC=https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
ALCHEMY_RPC_POLYGON=https://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

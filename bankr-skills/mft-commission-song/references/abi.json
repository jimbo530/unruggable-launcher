{
  "note": "Minimal ABIs for the mft-commission-song skill on Base. The fan approves the band's ERC-20, then calls CommissionBooth.commission(bandId, idea, handle). Booth address is FILL_AFTER_DEPLOY (see references/addresses.json).",
  "erc20": [
    { "type": "function", "name": "approve", "stateMutability": "nonpayable", "inputs": [ { "name": "spender", "type": "address" }, { "name": "amount", "type": "uint256" } ], "outputs": [ { "name": "", "type": "bool" } ] },
    { "type": "function", "name": "allowance", "stateMutability": "view", "inputs": [ { "name": "owner", "type": "address" }, { "name": "spender", "type": "address" } ], "outputs": [ { "name": "", "type": "uint256" } ] },
    { "type": "function", "name": "balanceOf", "stateMutability": "view", "inputs": [ { "name": "account", "type": "address" } ], "outputs": [ { "name": "", "type": "uint256" } ] }
  ],
  "commissionBooth": [
    { "type": "function", "name": "commission", "stateMutability": "nonpayable", "inputs": [ { "name": "bandId", "type": "uint8" }, { "name": "idea", "type": "string" }, { "name": "handle", "type": "string" } ], "outputs": [] },
    { "type": "function", "name": "bands", "stateMutability": "view", "inputs": [ { "name": "", "type": "uint8" } ], "outputs": [ { "name": "token", "type": "address" }, { "name": "price", "type": "uint256" }, { "name": "active", "type": "bool" } ] },
    { "type": "function", "name": "paused", "stateMutability": "view", "inputs": [], "outputs": [ { "name": "", "type": "bool" } ] }
  ],
  "selectors": {
    "approve(address,uint256)": "0x095ea7b3",
    "commission(uint8,string,string)": "0xf2a50707",
    "allowance(address,address)": "0xdd62ed3e",
    "balanceOf(address)": "0x70a08231"
  }

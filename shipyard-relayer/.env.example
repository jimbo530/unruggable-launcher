# ─────────────────────────────────────────────────────────────────────────────
# Shipyard crew USDC payout keeper — example env
# Copy to .env and fill in. NEVER commit a real key. The keeper prints the signer
# ADDRESS only, never the key.
# ─────────────────────────────────────────────────────────────────────────────

# Base RPC. Use a keyed Alchemy/Infura URL for reliability; falls back to the
# public Base RPC if unset.
ALCHEMY_RPC=https://mainnet.base.org

# ── Targets ──────────────────────────────────────────────────────────────────
# Option 1 (recommended): let the keeper auto-discover every launch's crew
# distributor from the Shipyard factory. This is the FINAL/LIVE Shipyard,
# verified in deploy/shipyard-FINAL-deployed.json — do not invent another.
SHIPYARD_ADDRESS=0x1afBe7101Acc6460d8793e17c40f9aa5Bbd7D573

# Option 2 (overrides discovery): target specific distributors only. Comma-
# separated FeeShareDistributor addresses. The reactor + payout token for each
# are read on-chain from the distributor itself. Leave blank to use discovery.
# DISTRIBUTOR_ADDRESSES=0x...,0x...

# USDC on Base (the distributor payout token). For reference only — the keeper
# reads token() from each distributor on-chain; it does not need this value.
# USDC=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# ── Signer (only required when DRY_RUN=false) ────────────────────────────────
# Any funded Base wallet works: claimAll/execute are permissionless and ALWAYS
# pay ownerOf(id), never the caller — the signer only ever spends its own gas
# and can never take crew USDC. You may reuse the existing Shipyard relayer key.
# PAYOUT_KEY (preferred) or RELAYER_KEY. PLACEHOLDER ONLY — paste your own:
PAYOUT_KEY=0xYOUR_PRIVATE_KEY_HERE

# ── Behaviour ────────────────────────────────────────────────────────────────
# "false" actually sends txs. ANYTHING ELSE (or unset) = DRY-RUN (sends nothing).
DRY_RUN=true

# "true" also fires reactor.execute() to top up the distributor with fresh USDC
# (only when its 2h cooldown has elapsed and it is not paused). Default off so
# the keeper never burns the cooldown on empty fees. Leave off if a separate
# reactor keeper / the trading cadence already drives execute().
TRIGGER_REACTOR=false

# Skip a distributor whose TOTAL claimable USDC is below this (whole USDC).
# Guards against spending more gas than the dust being distributed.
MIN_CLAIM_USDC=0.10

# Crew NFT ids per claimAll tx (1..100). 50 keeps each tx well under gas limits.
CLAIM_BATCH=50

# Loop interval in ms (default 5 min). Set ONCE=true for a single pass then exit.
POLL_MS=300000
ONCE=false

# Warn (log only) if the signer's ETH drops below this, in live mode.
MIN_ETH_WARN=0.0004

# Explicit gasLimit for reactor.execute() when TRIGGER_REACTOR=true. 8M is well
# above what 2 pools need and far under Base's block limit.
EXECUTE_GAS=8000000

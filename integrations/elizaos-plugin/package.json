{
  "name": "@elizaos/plugin-unrugable",
  "version": "1.0.0",
  "description": "ElizaOS plugin for the Unrugable Launcher on Base. Query tokenomics, launched tokens, reactor status, swap quotes, and infrastructure token data.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "elizaos",
    "elizaos-plugin",
    "defi",
    "base",
    "unrugable",
    "mft",
    "reactor",
    "carbon",
    "ai-agent",
    "memefortrees"
  ],
  "author": "memefortrees",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/memefortrees/plugin-unrugable"
  },
  "agentConfig": {
    "pluginType": "elizaos:plugin:1.0.0",
    "pluginParameters": {
      "UNRUGABLE_RPC_URL": {
        "type": "string",
        "description": "Base chain RPC URL (defaults to https://mainnet.base.org)",
        "optional": true
      },
      "UNRUGABLE_PRIVATE_KEY": {
        "type": "string",
        "description": "Private key for swap execution (optional, only needed for EXECUTE_SWAP action)",
        "optional": true
      }
    }
  },
  "dependencies": {
    "ethers": "^6.13.0"
  },
  "peerDependencies": {
    "@elizaos/core": ">=0.1.7"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}

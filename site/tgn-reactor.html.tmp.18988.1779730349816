<!DOCTYPE html>
<html><head>
<title>TGN Public Reactor - Burn TGN, Earn Distributions</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<style>
  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap');

  :root {
    --lime: #c5d94a;
    --lime-dim: #8fa832;
    --lime-glow: rgba(197, 217, 74, 0.3);
    --brown: #2d2117;
    --brown-light: #4a3828;
    --glass: rgba(20, 18, 14, 0.75);
    --glass-border: rgba(197, 217, 74, 0.15);
    --glass-hover: rgba(30, 28, 22, 0.85);
    --text: #e8e4dc;
    --text-dim: #9a9484;
    --red: #e85d4a;
    --gold: #d4a843;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    min-height: 100vh;
    background: #0c0a08;
    color: var(--text);
    font-family: 'Space Grotesk', sans-serif;
    overflow-x: hidden;
  }

  /* Background */
  .bg-layer {
    position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 0;
    background: url('assets/tgn/bg.jpg') center/cover no-repeat;
  }
  .bg-overlay {
    position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 1;
    background: linear-gradient(180deg, rgba(10,8,6,0.88) 0%, rgba(10,8,6,0.7) 40%, rgba(10,8,6,0.85) 100%);
  }

  .container {
    position: relative; z-index: 2;
    max-width: 920px; margin: 0 auto; padding: 24px 20px 60px;
  }

  /* Header */
  .header {
    display: flex; align-items: center; gap: 20px;
    padding: 20px 0 12px;
  }
  .header img {
    width: 72px; height: 72px; border-radius: 16px;
    border: 2px solid var(--lime);
    box-shadow: 0 0 20px var(--lime-glow);
  }
  .header-text h1 {
    font-size: 32px; font-weight: 700; color: var(--lime);
    text-shadow: 0 0 30px var(--lime-glow);
    letter-spacing: -0.5px;
  }
  .header-text p {
    color: var(--text-dim); font-size: 14px; margin-top: 2px;
  }

  .top-bar {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: 20px;
  }

  /* Glass cards */
  .glass {
    background: var(--glass);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid var(--glass-border);
    border-radius: 12px;
    padding: 20px;
    margin-bottom: 16px;
  }

  /* Buttons */
  button {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 600; font-size: 13px;
    padding: 10px 20px;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s;
    border: none;
  }
  .btn-primary {
    background: var(--lime); color: var(--brown);
    box-shadow: 0 0 12px var(--lime-glow);
  }
  .btn-primary:hover { background: #d4e85a; box-shadow: 0 0 20px var(--lime-glow); }
  .btn-primary:disabled { opacity: 0.4; cursor: not-allowed; box-shadow: none; }

  .btn-outline {
    background: transparent; color: var(--lime);
    border: 1px solid var(--lime);
  }
  .btn-outline:hover { background: rgba(197, 217, 74, 0.1); }

  .btn-ghost {
    background: rgba(255,255,255,0.05); color: var(--text-dim);
    border: 1px solid rgba(255,255,255,0.1);
  }
  .btn-ghost:hover { background: rgba(255,255,255,0.1); color: var(--text); }

  .btn-danger {
    background: rgba(232, 93, 74, 0.15); color: var(--red);
    border: 1px solid rgba(232, 93, 74, 0.3);
  }
  .btn-danger:hover { background: rgba(232, 93, 74, 0.25); }

  .btn-sm { padding: 6px 14px; font-size: 12px; }
  .btn-lg { padding: 14px 28px; font-size: 15px; }

  /* Inputs */
  input, select {
    font-family: 'Space Grotesk', sans-serif;
    background: rgba(0,0,0,0.4);
    color: var(--text);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 8px;
    padding: 10px 12px;
    font-size: 14px;
    width: 100%;
    margin: 4px 0;
    transition: border-color 0.2s;
  }
  input:focus, select:focus {
    border-color: var(--lime);
    outline: none;
    box-shadow: 0 0 8px rgba(197, 217, 74, 0.15);
  }
  select option { background: #1a1814; }

  label {
    font-size: 11px; color: var(--text-dim);
    text-transform: uppercase; letter-spacing: 1px;
    display: block; margin-top: 10px; margin-bottom: 2px;
  }

  /* Stats bar */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 12px;
  }
  .stat-item {
    text-align: center; padding: 12px 8px;
    background: rgba(0,0,0,0.3);
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,0.05);
  }
  .stat-value {
    font-size: 20px; font-weight: 700; color: var(--lime);
    display: block;
  }
  .stat-label {
    font-size: 10px; color: var(--text-dim);
    text-transform: uppercase; letter-spacing: 1.5px;
    margin-top: 4px;
  }

  /* Countdown */
  .countdown-box {
    text-align: center; padding: 16px;
    background: linear-gradient(135deg, rgba(197, 217, 74, 0.08), rgba(45, 33, 23, 0.3));
    border: 1px solid rgba(197, 217, 74, 0.2);
    border-radius: 10px;
    margin-top: 12px;
  }
  .countdown-label {
    font-size: 11px; color: var(--text-dim);
    text-transform: uppercase; letter-spacing: 1.5px;
    margin-bottom: 6px;
  }
  .countdown-title {
    font-size: 16px; font-weight: 600; color: var(--lime);
    margin-bottom: 4px;
  }
  .countdown-timer {
    font-size: 24px; font-weight: 700; color: var(--text);
    font-variant-numeric: tabular-nums;
  }
  .countdown-timer .unit {
    font-size: 11px; font-weight: 400; color: var(--text-dim);
    margin: 0 2px;
  }

  /* Dust balances */
  .dust-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: 8px;
    margin-top: 12px;
  }
  .dust-item {
    text-align: center; padding: 10px 6px;
    background: rgba(0,0,0,0.25);
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,0.04);
  }
  .dust-value {
    font-size: 14px; font-weight: 600; color: var(--text);
    display: block;
  }
  .dust-label {
    font-size: 10px; color: var(--text-dim);
    text-transform: uppercase; letter-spacing: 1px;
    margin-top: 2px;
  }

  /* Tabs */
  .tabs {
    display: flex; gap: 4px; margin-bottom: 0;
    border-bottom: 1px solid var(--glass-border);
    padding-bottom: 0;
  }
  .tab {
    padding: 10px 20px;
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 500; font-size: 13px;
    color: var(--text-dim);
    cursor: pointer;
    border: none; background: none;
    border-bottom: 2px solid transparent;
    transition: all 0.2s;
  }
  .tab:hover { color: var(--text); }
  .tab.active {
    color: var(--lime);
    border-bottom-color: var(--lime);
  }

  .tab-content {
    padding: 20px 0;
  }

  /* Table */
  table { width: 100%; border-collapse: collapse; }
  th {
    text-align: left; font-size: 10px;
    text-transform: uppercase; letter-spacing: 1.5px;
    color: var(--text-dim); padding: 8px 10px;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  td {
    padding: 10px; font-size: 13px;
    border-bottom: 1px solid rgba(255,255,255,0.04);
  }
  tr:hover td { background: rgba(255,255,255,0.02); }

  /* Badges */
  .badge {
    display: inline-block; padding: 3px 10px;
    border-radius: 20px; font-size: 11px; font-weight: 600;
  }
  .badge.locked {
    background: rgba(212, 168, 67, 0.15); color: var(--gold);
    border: 1px solid rgba(212, 168, 67, 0.3);
  }
  .badge.unlocked {
    background: rgba(197, 217, 74, 0.15); color: var(--lime);
    border: 1px solid rgba(197, 217, 74, 0.3);
  }
  .badge.withdrawn {
    background: rgba(255,255,255,0.05); color: #666;
    border: 1px solid rgba(255,255,255,0.08);
  }
  .badge.disabled {
    background: rgba(232, 93, 74, 0.1); color: var(--red);
    border: 1px solid rgba(232, 93, 74, 0.2);
  }
  .badge.active {
    background: rgba(197, 217, 74, 0.15); color: var(--lime);
    border: 1px solid rgba(197, 217, 74, 0.3);
  }

  /* Log */
  #log {
    background: rgba(0,0,0,0.5);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 8px;
    padding: 12px 14px;
    margin: 12px 0;
    max-height: 160px;
    overflow-y: auto;
    font-size: 12px;
    font-family: 'Space Grotesk', monospace;
    white-space: pre-wrap;
  }
  #log:empty { display: none; }

  .ok { color: var(--lime); }
  .err { color: var(--red); }
  .info { color: var(--text-dim); }
  .warn { color: var(--gold); }

  /* Layout helpers */
  .row { display: flex; gap: 12px; align-items: end; flex-wrap: wrap; }
  .row > * { flex: 1; min-width: 150px; }
  .hidden { display: none !important; }
  .mt { margin-top: 16px; }
  .mb { margin-bottom: 12px; }
  .gap { display: flex; gap: 8px; flex-wrap: wrap; }

  /* Public actions */
  .public-actions {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 12px;
  }
  .action-card {
    background: linear-gradient(135deg, rgba(197, 217, 74, 0.06), rgba(45, 33, 23, 0.3));
    border: 1px solid rgba(197, 217, 74, 0.15);
    border-radius: 12px;
    padding: 20px;
    text-align: center;
  }
  .action-card h3 {
    font-size: 14px; color: var(--lime); margin-bottom: 6px;
  }
  .action-card p {
    font-size: 12px; color: var(--text-dim); margin-bottom: 12px;
    line-height: 1.4;
  }
  .action-card .last-event {
    font-size: 10px; color: var(--text-dim); margin-top: 8px;
    opacity: 0.7;
  }

  /* Deposit section */
  .deposit-box {
    background: linear-gradient(135deg, rgba(197, 217, 74, 0.05), rgba(45, 33, 23, 0.3));
    border: 1px solid rgba(197, 217, 74, 0.12);
    border-radius: 12px;
    padding: 24px;
  }

  .balance-row {
    display: flex; justify-content: space-between;
    font-size: 12px; color: var(--text-dim);
    margin-top: 4px; padding: 0 4px;
  }

  /* Token pair inputs */
  .token-pair {
    display: flex; gap: 12px; align-items: start; margin-top: 8px;
  }
  .token-pair .token-side { flex: 1; min-width: 0; }
  .token-pair-plus {
    font-size: 28px; color: var(--lime); font-weight: 700;
    padding-top: 28px; flex-shrink: 0; line-height: 1;
    text-shadow: 0 0 12px var(--lime-glow);
  }
  .input-with-max { position: relative; }
  .input-with-max input { padding-right: 54px; }
  .btn-max {
    position: absolute; right: 6px; top: 50%; transform: translateY(-50%);
    background: rgba(197, 217, 74, 0.15); color: var(--lime);
    border: 1px solid rgba(197, 217, 74, 0.3);
    padding: 3px 8px; border-radius: 4px; font-size: 10px;
    font-weight: 700; cursor: pointer; font-family: 'Space Grotesk', sans-serif;
  }
  .btn-max:hover { background: rgba(197, 217, 74, 0.25); }
  .pool-ratio {
    font-size: 12px; color: var(--text-dim); margin-top: 10px;
    text-align: center; padding: 6px; border-radius: 6px;
    background: rgba(0,0,0,0.2);
  }
  .pool-ratio:empty { display: none; }

  .step-indicator {
    display: flex; gap: 4px; align-items: center; justify-content: center;
    margin-top: 10px; font-size: 11px; color: var(--text-dim);
  }
  .step { padding: 2px 8px; border-radius: 10px; background: rgba(255,255,255,0.05); }
  .step.active { background: rgba(197, 217, 74, 0.2); color: var(--lime); }
  .step.done { background: rgba(197, 217, 74, 0.3); color: var(--lime); }

  /* Lock slider */
  .slider-row {
    display: flex; align-items: center; gap: 12px; margin-top: 4px;
  }
  .slider-row input[type="range"] {
    flex: 1; margin: 0; padding: 0; border: none;
    background: transparent;
    -webkit-appearance: none;
    height: 6px;
  }
  .slider-row input[type="range"]::-webkit-slider-track {
    height: 6px; border-radius: 3px;
    background: rgba(255,255,255,0.1);
  }
  .slider-row input[type="range"]::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 18px; height: 18px; border-radius: 50%;
    background: var(--lime);
    box-shadow: 0 0 8px var(--lime-glow);
    cursor: pointer; margin-top: -6px;
  }
  .slider-row input[type="range"]::-moz-range-track {
    height: 6px; border-radius: 3px;
    background: rgba(255,255,255,0.1); border: none;
  }
  .slider-row input[type="range"]::-moz-range-thumb {
    width: 18px; height: 18px; border-radius: 50%;
    background: var(--lime); border: none;
    box-shadow: 0 0 8px var(--lime-glow);
    cursor: pointer;
  }
  .slider-value {
    font-size: 14px; font-weight: 600; color: var(--lime);
    min-width: 60px; text-align: right;
  }

  /* Section title */
  .section-title {
    font-size: 13px; font-weight: 600; color: var(--text);
    text-transform: uppercase; letter-spacing: 1.5px;
    margin-bottom: 12px;
  }

  /* Powered by footer */
  .footer {
    text-align: center; margin-top: 40px;
    font-size: 11px; color: var(--text-dim);
    opacity: 0.6;
  }
  .footer a { color: var(--lime); text-decoration: none; }
  .footer .links { margin-top: 8px; }
  .footer .links a { margin: 0 10px; }

  /* Responsive */
  @media (max-width: 600px) {
    .header img { width: 52px; height: 52px; }
    .header-text h1 { font-size: 24px; }
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
    .row > * { min-width: 120px; }
    .token-pair { flex-direction: column; gap: 4px; }
    .token-pair-plus { padding-top: 0; text-align: center; }
    .public-actions { grid-template-columns: 1fr; }
    .dust-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
</head><body>

<div class="bg-layer"></div>
<div class="bg-overlay"></div>

<div class="container">

  <!-- Header -->
  <div class="top-bar">
    <div class="header">
      <img src="assets/tgn/logo.jpg" alt="TGN">
      <div class="header-text">
        <h1>TGN Public Reactor</h1>
        <p>Lock V3 positions. Burn TGN. Earn distributions.</p>
      </div>
    </div>
    <button class="btn-primary" id="connectBtn" onclick="connect()">Connect Wallet</button>
  </div>

  <div id="log"></div>

  <!-- Stats Dashboard -->
  <div class="glass">
    <div class="stats-grid">
      <div class="stat-item">
        <span class="stat-value" id="statBurned">-</span>
        <div class="stat-label">TGN Burned</div>
      </div>
      <div class="stat-item">
        <span class="stat-value" id="statLiquidity">-</span>
        <div class="stat-label">Total Liquidity</div>
      </div>
      <div class="stat-item">
        <span class="stat-value" id="statDeposits">-</span>
        <div class="stat-label">Active Deposits</div>
      </div>
      <div class="stat-item">
        <span class="stat-value" id="statPools">-</span>
        <div class="stat-label">Pools</div>
      </div>
      <div class="stat-item">
        <span class="stat-value" id="statStatus">-</span>
        <div class="stat-label">Status</div>
      </div>
    </div>

    <!-- Distribution Countdown -->
    <div class="countdown-box" id="countdownBox">
      <div class="countdown-label">Next Distribution</div>
      <div class="countdown-title" id="countdownTitle">--</div>
      <div class="countdown-timer" id="countdownTimer">--</div>
    </div>

    <!-- Accumulated Dust Balances -->
    <div id="dustSection" class="hidden">
      <div class="section-title" style="margin-top:14px;">Accumulated for Distribution</div>
      <div class="dust-grid" id="dustGrid"></div>
    </div>
  </div>

  <!-- Tabs -->
  <div class="tabs">
    <div class="tab active" onclick="showTab('actions')">Public Actions</div>
    <div class="tab" onclick="showTab('deposit')">Deposit</div>
    <div class="tab" onclick="showTab('mydeposits')">My Deposits</div>
    <div class="tab" onclick="showTab('pools')">Pools</div>
  </div>

  <!-- Public Actions Tab -->
  <div class="tab-content" id="tab-actions">
    <div class="public-actions">

      <div class="action-card">
        <h3>Collect Fees</h3>
        <p>Collect accrued trading fees from all deposited V3 positions. TGN fees are auto-burned.</p>
        <button class="btn-primary" onclick="doCollectFees()" style="width:100%;">Collect Fees</button>
        <div class="last-event" id="lastCollect">--</div>
      </div>

      <div class="action-card">
        <h3>Burn TGN</h3>
        <p>Send accumulated TGN to the burn address. Reduces supply forever.</p>
        <button class="btn-danger" onclick="doBurnTGN()" style="width:100%;padding:10px 20px;">Burn TGN</button>
        <div class="last-event" id="lastBurn">--</div>
      </div>

      <div class="action-card">
        <h3>Distribute Tokens</h3>
        <p>Distribute collected non-TGN fees to depositors, proportional to liquidity.</p>
        <label>Token to Distribute</label>
        <select id="distToken" style="margin-bottom:8px;">
          <option value="">Select token...</option>
        </select>
        <button class="btn-primary" id="distBtn" onclick="doDistribute()" style="width:100%;" disabled>Distribute</button>
        <div class="last-event" id="lastDist">--</div>
      </div>

    </div>
  </div>

  <!-- Deposit Tab -->
  <div class="tab-content hidden" id="tab-deposit">
    <div class="deposit-box">
      <label>Pool (TGN paired with)</label>
      <select id="depPool" onchange="onPoolSelect()">
        <option value="">Select a pool...</option>
        <option value="mftstable">TGN / MfT Stable</option>
        <option value="mft">TGN / MfT</option>
        <option value="teth">TGN / TETH</option>
        <option value="tbtc">TGN / TBTC</option>
        <option value="weth">TGN / WETH</option>
        <option value="custom">Custom (enter address)</option>
      </select>
      <input id="customTokenAddr" class="hidden" placeholder="Paste token contract address..." style="margin-top:4px;">
      <div id="poolStatus" style="font-size:12px;margin-top:4px;min-height:18px;"></div>

      <div class="token-pair">
        <div class="token-side">
          <label>TGN Amount</label>
          <div class="input-with-max">
            <input id="amount0" placeholder="0.0" type="text">
            <button class="btn-max" onclick="maxToken(0)">MAX</button>
          </div>
          <div class="balance-row"><span>Balance: <span id="bal0">-</span></span></div>
        </div>
        <div class="token-pair-plus">+</div>
        <div class="token-side">
          <label id="token1Label">Token X Amount</label>
          <div class="input-with-max">
            <input id="amount1" placeholder="0.0" type="text">
            <button class="btn-max" onclick="maxToken(1)">MAX</button>
          </div>
          <div class="balance-row"><span>Balance: <span id="bal1">-</span></span></div>
        </div>
      </div>

      <div class="pool-ratio" id="poolRatio"></div>

      <label>Lock Duration</label>
      <div class="slider-row">
        <input type="range" id="lockSlider" min="7" max="365" value="30" oninput="updateSlider()">
        <span class="slider-value" id="lockDisplay">30 days</span>
      </div>

      <div class="mt">
        <button class="btn-primary" id="depositBtn" onclick="doDeposit()" style="width:100%;padding:14px;font-size:15px;">
          Mint Position &amp; Deposit
        </button>
      </div>
      <div class="step-indicator" id="steps"></div>
    </div>
  </div>

  <!-- My Deposits Tab -->
  <div class="tab-content hidden" id="tab-mydeposits">
    <div class="glass">
      <div id="myDepositsList"><p style="color:var(--text-dim)">Connect wallet to view your deposits</p></div>
    </div>
  </div>

  <!-- Pools Tab -->
  <div class="tab-content hidden" id="tab-pools">
    <div class="glass">
      <div id="poolsList"><p style="color:var(--text-dim)">Loading pools...</p></div>
    </div>
  </div>

  <div class="footer">
    Powered by <a href="https://tasern.quest">Unrugable</a> Reactor Technology
    <div class="links">
      <a href="REACTOR_ADDRESS_BASESCAN" target="_blank">View Contract</a>
      <a href="partner-reactor.html">Partner Reactor</a>
    </div>
  </div>
</div>

<script type="module">
import { ethers } from "https://cdnjs.cloudflare.com/ajax/libs/ethers/6.13.4/ethers.min.js";
window.ethers = ethers;

// ── Addresses ──
const REACTOR = 'REACTOR_ADDRESS_HERE';
const TGN = '0xD75dfa972C6136f1c594Fec1945302f885E1ab29';
const NPM = '0x03a520b32C04BF3bEEf7BEb72E919cf822Ed34f1';
const SWAP_ROUTER = '0x2626664c2603336E57B271c5C0b26F421741e481';
const V3_FACTORY = '0x33128a8fC17869897dcE68Ed026d694621f6FDfD';
const MFT = '0x8FB87d13B40B1A67B22ED1a17e2835fe7e3a9bA3';
const MFT_STABLE = '0xe96fa44b4b82F085a457F9B7a0F85ea26FF1652F';
const TETH = '0x7D545427c8f548F3A00C1c09B5360BF3D4B842ef';
const TBTC = '0x53B6De1726856c4615dc3B05d45993Bc1aa3403c';

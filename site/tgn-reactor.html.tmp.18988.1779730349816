// ── Deposit flow ──
window.doDeposit = async function() {
  if (!selectedPool || !signer || !userAddr) {
    log('Select a pool and connect wallet first', 'err');
    return;
  }

  const val0 = document.getElementById('amount0').value;
  const val1 = document.getElementById('amount1').value;
  if (!val0 || !val1 || Number(val0) <= 0 || Number(val1) <= 0) {
    log('Enter amounts for both tokens', 'err');
    return;
  }

  const lockDays = Number(document.getElementById('lockSlider').value);
  const lockDuration = lockDays * 86400;

  const tgnInfo = await getTokenInfo(TGN);
  const xInfo = await getTokenInfo(selectedPool.tokenXAddr);
  const tgnDecimals = tgnInfo.decimals;
  const xDecimals = xInfo.decimals;

  // Determine which is token0 and token1 in the V3 pool
  const tgnIsToken0 = selectedPool.tgnIsToken0;
  const token0Addr = selectedPool.token0;
  const token1Addr = selectedPool.token1;
  const dec0 = selectedPool.dec0;
  const dec1 = selectedPool.dec1;

  const amountTgn = ethers.parseUnits(val0, tgnDecimals);
  const amountX = ethers.parseUnits(val1, xDecimals);

  // Order amounts to match token0/token1
  const amount0Desired = tgnIsToken0 ? amountTgn : amountX;
  const amount1Desired = tgnIsToken0 ? amountX : amountTgn;

  // 1% slippage
  const amount0Min = amount0Desired * 99n / 100n;
  const amount1Min = amount1Desired * 99n / 100n;

  // Full-range ticks aligned to tick spacing
  const ts = selectedPool.tickSpacing;
  const tickLower = Math.ceil(MIN_TICK / ts) * ts;
  const tickUpper = Math.floor(MAX_TICK / ts) * ts;

  const deadline = Math.floor(Date.now() / 1000) + 600;

  const btn = document.getElementById('depositBtn');
  btn.disabled = true;

  try {
    // Step 1: Approve TGN to NPM
    showSteps(1);
    const tgnContract = new ethers.Contract(TGN, ERC20_ABI, signer);
    const allow0 = await tgnContract.allowance(userAddr, NPM);
    if (allow0 < amountTgn) {
      log('Approving TGN to Position Manager...', 'info');
      const tx = await tgnContract.approve(NPM, ethers.MaxUint256);
      await tx.wait();
      log('TGN approved', 'ok');
    } else {
      log('TGN already approved', 'info');
    }

    // Step 2: Approve Token X to NPM
    showSteps(2);
    const xContract = new ethers.Contract(selectedPool.tokenXAddr, ERC20_ABI, signer);
    const allow1 = await xContract.allowance(userAddr, NPM);
    if (allow1 < amountX) {
      log(`Approving ${xInfo.symbol} to Position Manager...`, 'info');
      const tx = await xContract.approve(NPM, ethers.MaxUint256);
      await tx.wait();
      log(`${xInfo.symbol} approved`, 'ok');
    } else {
      log(`${xInfo.symbol} already approved`, 'info');
    }

    // Step 3: Mint V3 position
    showSteps(3);
    log(`Minting V3 position (${val0} TGN + ${val1} ${xInfo.symbol})...`, 'info');
    const npm = new ethers.Contract(NPM, NPM_ABI, signer);

    const mintParams = {
      token0: token0Addr,
      token1: token1Addr,
      fee: selectedPool.fee,
      tickLower: tickLower,
      tickUpper: tickUpper,
      amount0Desired: amount0Desired,
      amount1Desired: amount1Desired,
      amount0Min: amount0Min,
      amount1Min: amount1Min,
      recipient: userAddr,
      deadline: deadline
    };

    const mintTx = await npm.mint(mintParams);
    const receipt = await mintTx.wait();

    // Parse tokenId from Transfer event (ERC721 Transfer to user)
    let tokenId = null;
    for (const eventLog of receipt.logs) {
      // ERC721 Transfer: Transfer(address,address,uint256)
      // topic0 = 0xddf252ad...
      if (eventLog.topics && eventLog.topics.length === 4 &&
          eventLog.topics[0] === '0xddf252ad1be2c89b69c2b068fc378daa952ba7f163c4a11628f55a4df523b3ef' &&
          eventLog.address.toLowerCase() === NPM.toLowerCase()) {
        tokenId = BigInt(eventLog.topics[3]);
        break;
      }
    }

    if (!tokenId) {
      log('Could not find minted position tokenId in receipt', 'err');
      btn.disabled = false;
      return;
    }

    log(`Minted position NFT #${tokenId}`, 'ok');

    // Step 4: Approve NFT to reactor
    showSteps(4);
    log('Approving NFT to reactor...', 'info');
    const approveTx = await npm.approve(REACTOR, tokenId);
    await approveTx.wait();
    log('NFT approved', 'ok');

    // Step 5: Deposit to reactor
    showSteps(5);
    log(`Depositing position #${tokenId} with ${lockDays}-day lock...`, 'info');
    const depTx = await reactor.depositPosition(tokenId, lockDuration);
    await depTx.wait();
    log(`Position locked for ${lockDays} days! Your LP is secured in the reactor.`, 'ok');

    showSteps(6);
    await refresh();
  } catch(e) {
    log('Deposit failed: ' + (e.reason || e.shortMessage || e.message), 'err');
  }

  btn.disabled = false;
};

function showSteps(current) {
  const names = ['Approve TGN', 'Approve X', 'Mint Position', 'Approve NFT', 'Deposit'];
  const el = document.getElementById('steps');
  el.innerHTML = names.map((n, i) => {
    const cls = (i + 1) < current ? 'step done' : (i + 1) === current ? 'step active' : 'step';
    return `<span class="${cls}">${n}</span>`;
  }).join('');
}


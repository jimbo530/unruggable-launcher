    const tokenXAddr = preset.token;
    const tX = await getTokenInfo(tokenXAddr);
    document.getElementById('token1Label').textContent = tX.symbol + ' Amount';

    // Find matching pool in reactor
    let matchIdx = -1;
    for (let i = 0; i < poolsCache.length; i++) {
      const p = poolsCache[i];
      if (p.disabled) continue;
      const has0 = p.token0.toLowerCase() === tokenXAddr.toLowerCase() || p.token1.toLowerCase() === tokenXAddr.toLowerCase();
      const hasTgn = p.token0.toLowerCase() === TGN.toLowerCase() || p.token1.toLowerCase() === TGN.toLowerCase();
      if (has0 && hasTgn) { matchIdx = i; break; }
    }

    if (matchIdx < 0) {
      statusEl.innerHTML = `<span class="warn">No TGN/${tX.symbol} pool registered in reactor. Ask admin to add it.</span>`;
      return;
    }

    const pool = poolsCache[matchIdx];
    const tgnIsToken0 = pool.token0.toLowerCase() === TGN.toLowerCase();

    // Get tick spacing from V3 pool
    const v3Pool = new ethers.Contract(pool.v3Pool, V3_POOL_ABI, provider);
    const [slot0Data, tickSpacing] = await Promise.all([v3Pool.slot0(), v3Pool.tickSpacing()]);

    selectedPool = {
      poolIndex: matchIdx,
      v3Pool: pool.v3Pool,
      token0: pool.token0,
      token1: pool.token1,
      fee: pool.fee,
      tickSpacing: Number(tickSpacing),
      tgnIsToken0,
      tokenXAddr,
      dec0: pool.dec0,
      dec1: pool.dec1,
      sym0: pool.sym0,
      sym1: pool.sym1
    };

    statusEl.innerHTML = `<span class="ok">TGN / ${tX.symbol} - Pool #${matchIdx} (${(pool.fee / 10000).toFixed(2)}% fee) ready</span>`;

    // Load balances
    if (userAddr) {
      const tgnInfo = await getTokenInfo(TGN);
      const [balTgn, balX] = await Promise.all([
        tgnInfo.contract.balanceOf(userAddr),
        tX.contract.balanceOf(userAddr)
      ]);
      document.getElementById('bal0').textContent = trimDecimals(ethers.formatUnits(balTgn, tgnInfo.decimals));
      document.getElementById('bal1').textContent = trimDecimals(ethers.formatUnits(balX, tX.decimals));
    }

    // Show current price from slot0
    const sqrtPriceX96 = slot0Data[0];
    const price = Number(sqrtPriceX96) ** 2 / (2 ** 192);
    // price is token1/token0 ratio in raw units
    const adjPrice = price * (10 ** pool.dec0) / (10 ** pool.dec1);
    const tgnSymbol = tgnIsToken0 ? pool.sym0 : pool.sym1;
    const xSymbol = tgnIsToken0 ? pool.sym1 : pool.sym0;
    if (tgnIsToken0) {
      document.getElementById('poolRatio').textContent =
        `1 TGN = ${trimDecimals(adjPrice.toFixed(8))} ${xSymbol}  |  1 ${xSymbol} = ${trimDecimals((1/adjPrice).toFixed(8))} TGN`;
    } else {
      document.getElementById('poolRatio').textContent =
        `1 TGN = ${trimDecimals((1/adjPrice).toFixed(8))} ${xSymbol}  |  1 ${xSymbol} = ${trimDecimals(adjPrice.toFixed(8))} TGN`;
    }

  } catch(e) {
    statusEl.innerHTML = `<span class="err">${e.reason || e.shortMessage || e.message}</span>`;
  }
};


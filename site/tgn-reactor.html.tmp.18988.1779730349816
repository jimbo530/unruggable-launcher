// ── Connect ──
window.connect = async function() {
  try {
    if (!window.ethereum) { log('No wallet detected. Install MetaMask.', 'err'); return; }
    provider = new ethers.BrowserProvider(window.ethereum);
    const net = await provider.getNetwork();
    if (net.chainId !== 8453n) { log('Please switch to Base network (chainId 8453)', 'err'); return; }
    signer = await provider.getSigner();
    userAddr = await signer.getAddress();
    reactor = new ethers.Contract(REACTOR, REACTOR_ABI, signer);
    reactorRead = new ethers.Contract(REACTOR, REACTOR_ABI, provider);
    document.getElementById('connectBtn').textContent = short(userAddr);
    document.getElementById('connectBtn').classList.remove('btn-primary');
    document.getElementById('connectBtn').classList.add('btn-outline');
    log('Connected: ' + userAddr, 'ok');
    await refresh();
  } catch(e) { log('Connect failed: ' + (e.reason || e.shortMessage || e.message), 'err'); }
};

// ── Token info helper ──
async function getTokenInfo(addr) {
  const key = addr.toLowerCase();
  if (tokenCache[key]) return tokenCache[key];
  const p = provider || new ethers.BrowserProvider(window.ethereum);
  const c = new ethers.Contract(addr, ERC20_ABI, p);
  const [symbol, decimals] = await Promise.all([c.symbol(), c.decimals()]);
  tokenCache[key] = { symbol, decimals: Number(decimals), contract: c, address: addr };
  return tokenCache[key];
}

// ── Refresh all data ──
async function refresh() {
  const p = provider || new ethers.BrowserProvider(window.ethereum);
  const rc = new ethers.Contract(REACTOR, REACTOR_ABI, p);

  const [burned, liquidity, depCount, poolCount, paused, nextDist] = await Promise.all([
    rc.totalTGNBurned(),
    rc.totalLiquidity(),
    rc.depositCount(),
    rc.poolCount(),
    rc.paused(),
    rc.nextDistributionDate()
  ]);

  const tgnInfo = await getTokenInfo(TGN);
  document.getElementById('statBurned').textContent = trimDecimals(ethers.formatUnits(burned, tgnInfo.decimals));
  document.getElementById('statLiquidity').textContent = liquidity.toString();
  document.getElementById('statDeposits').textContent = depCount.toString();
  document.getElementById('statPools').textContent = poolCount.toString();
  document.getElementById('statStatus').textContent = paused ? 'PAUSED' : 'LIVE';
  document.getElementById('statStatus').style.color = paused ? 'var(--red)' : 'var(--lime)';

  // Distribution countdown
  updateCountdown(Number(nextDist));

  // Load pools
  poolsCache = [];
  const nPools = Number(poolCount);
  for (let i = 0; i < nPools; i++) {
    const pool = await rc.pools(i);
    const t0 = await getTokenInfo(pool.token0);
    const t1 = await getTokenInfo(pool.token1);
    poolsCache.push({
      index: i,
      v3Pool: pool.v3Pool,
      token0: pool.token0,
      token1: pool.token1,
      fee: Number(pool.fee),
      disabled: pool.disabled,
      sym0: t0.symbol,
      sym1: t1.symbol,
      dec0: t0.decimals,
      dec1: t1.decimals
    });
  }

  await loadPoolsTab();
  await loadDustBalances(rc);
  await loadDistributeDropdown();
  if (userAddr) await loadMyDeposits();
}

// ── Countdown ──
function updateCountdown(timestamp) {
  const box = document.getElementById('countdownBox');
  const titleEl = document.getElementById('countdownTitle');
  const timerEl = document.getElementById('countdownTimer');

  if (countdownInterval) clearInterval(countdownInterval);

  if (timestamp === 0) {
    titleEl.textContent = 'Not set';
    timerEl.textContent = '--';
    return;
  }

  // Show date label
  const distDate = new Date(timestamp * 1000);
  titleEl.textContent = 'Arbor Day 2027 - ' + distDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });

  function tick() {
    const now = Math.floor(Date.now() / 1000);
    const diff = timestamp - now;
    if (diff <= 0) {
      timerEl.innerHTML = '<span class="ok">DISTRIBUTION READY</span>';
      clearInterval(countdownInterval);
      return;
    }
    const days = Math.floor(diff / 86400);
    const hours = Math.floor((diff % 86400) / 3600);
    const mins = Math.floor((diff % 3600) / 60);
    const secs = diff % 60;
    timerEl.innerHTML =
      days + '<span class="unit">d</span> ' +
      String(hours).padStart(2, '0') + '<span class="unit">h</span> ' +
      String(mins).padStart(2, '0') + '<span class="unit">m</span> ' +
      String(secs).padStart(2, '0') + '<span class="unit">s</span>';
  }

  tick();
  countdownInterval = setInterval(tick, 1000);
}

// ── Dust balances (accumulated for distribution) ──
async function loadDustBalances(rc) {
  // Collect unique non-TGN tokens from all pools
  const tokenSet = new Set();
  for (const pool of poolsCache) {
    if (pool.token0.toLowerCase() !== TGN.toLowerCase()) tokenSet.add(pool.token0);
    if (pool.token1.toLowerCase() !== TGN.toLowerCase()) tokenSet.add(pool.token1);
  }

  const dustEl = document.getElementById('dustGrid');
  const section = document.getElementById('dustSection');
  if (tokenSet.size === 0) { section.classList.add('hidden'); return; }

  let html = '';
  let hasAny = false;
  for (const addr of tokenSet) {
    const bal = await rc.dustBalance(addr);
    const info = await getTokenInfo(addr);
    const formatted = trimDecimals(ethers.formatUnits(bal, info.decimals));
    if (bal > 0n) hasAny = true;
    html += `<div class="dust-item">
      <span class="dust-value">${formatted}</span>
      <div class="dust-label">${info.symbol}</div>
    </div>`;
  }

  // Also show TGN dust (pending burn)
  const tgnDust = await rc.dustBalance(TGN);
  const tgnInfo = await getTokenInfo(TGN);
  if (tgnDust > 0n) hasAny = true;
  html += `<div class="dust-item">
    <span class="dust-value" style="color:var(--red)">${trimDecimals(ethers.formatUnits(tgnDust, tgnInfo.decimals))}</span>
    <div class="dust-label">TGN (pending burn)</div>
  </div>`;

  dustEl.innerHTML = html;
  section.classList.toggle('hidden', !hasAny && poolsCache.length === 0);
  if (poolsCache.length > 0) section.classList.remove('hidden');
}

// ── Distribute dropdown ──
async function loadDistributeDropdown() {
  const sel = document.getElementById('distToken');
  sel.innerHTML = '<option value="">Select token...</option>';

  const tokenSet = new Set();
  for (const pool of poolsCache) {
    if (pool.token0.toLowerCase() !== TGN.toLowerCase()) tokenSet.add(pool.token0);
    if (pool.token1.toLowerCase() !== TGN.toLowerCase()) tokenSet.add(pool.token1);
  }

  for (const addr of tokenSet) {
    const info = await getTokenInfo(addr);
    const opt = document.createElement('option');
    opt.value = addr;
    opt.textContent = info.symbol;
    sel.appendChild(opt);
  }

  // Enable/disable based on distribution date
  updateDistributeBtn();
}

function updateDistributeBtn() {
  const btn = document.getElementById('distBtn');
  const sel = document.getElementById('distToken');
  btn.disabled = !sel.value;
}

document.getElementById('distToken').addEventListener('change', updateDistributeBtn);

// ── Pools Tab ──
async function loadPoolsTab() {
  const el = document.getElementById('poolsList');
  if (poolsCache.length === 0) {
    el.innerHTML = '<p style="color:var(--text-dim)">No pools registered yet</p>';
    return;
  }
  let html = '<table><tr><th>#</th><th>Pair</th><th>Fee</th><th>V3 Pool</th><th>Status</th></tr>';
  for (const p of poolsCache) {
    const st = p.disabled
      ? '<span class="badge disabled">Disabled</span>'
      : '<span class="badge active">Active</span>';
    const feePct = (p.fee / 10000).toFixed(2) + '%';
    html += `<tr>
      <td>${p.index}</td>
      <td><strong>${p.sym0} / ${p.sym1}</strong></td>
      <td>${feePct}</td>
      <td>${short(p.v3Pool)}</td>
      <td>${st}</td>
    </tr>`;
  }
  el.innerHTML = html + '</table>';
}

// ── My Deposits ──
async function loadMyDeposits() {
  const el = document.getElementById('myDepositsList');
  if (!userAddr) { el.innerHTML = '<p style="color:var(--text-dim)">Connect wallet to view your deposits</p>'; return; }

  try {
    const ids = await reactorRead.getDepositsBy(userAddr);
    if (ids.length === 0) {
      el.innerHTML = '<p style="color:var(--text-dim)">No deposits yet. Lock a V3 position to get started.</p>';
      return;
    }

    let html = '<table><tr><th>ID</th><th>NFT</th><th>Pool</th><th>Liquidity</th><th>Unlocks</th><th>Status</th><th></th></tr>';
    const now = Math.floor(Date.now() / 1000);

    for (const id of ids) {
      const d = await reactorRead.getDeposit(id);
      const depositor = d[0];
      const tokenId = Number(d[1]);
      const poolIdx = Number(d[2]);
      const liquidity = d[3];
      const unlockTime = Number(d[4]);
      const withdrawn = d[5];

      const poolLabel = poolsCache[poolIdx]
        ? `${poolsCache[poolIdx].sym0}/${poolsCache[poolIdx].sym1}`
        : `Pool #${poolIdx}`;

      let status, action = '';
      if (withdrawn) {
        status = '<span class="badge withdrawn">Withdrawn</span>';
      } else if (now >= unlockTime) {
        status = '<span class="badge unlocked">Ready</span>';
        action = `<button class="btn-primary btn-sm" onclick="doWithdraw(${id})">Withdraw</button>`;
      } else {
        const remaining = unlockTime - now;
        status = `<span class="badge locked">${fmtDuration(remaining)}</span>`;
      }

      html += `<tr>
        <td>#${id}</td>
        <td>#${tokenId}</td>
        <td>${poolLabel}</td>
        <td>${liquidity.toString()}</td>
        <td>${new Date(unlockTime * 1000).toLocaleDateString()}</td>
        <td>${status}</td>
        <td>${action}</td>
      </tr>`;
    }

    el.innerHTML = html + '</table>';
  } catch(e) {
    el.innerHTML = `<p class="err">Error loading deposits: ${e.reason || e.shortMessage || e.message}</p>`;
  }
}

